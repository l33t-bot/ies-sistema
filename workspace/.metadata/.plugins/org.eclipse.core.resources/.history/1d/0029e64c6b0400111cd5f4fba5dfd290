package ar.edu.ies.backend.service;

import java.util.List;
import java.util.stream.Collectors;

import org.springframework.stereotype.Service;

import ar.edu.ies.backend.dto.CorrelatividadDto;
import ar.edu.ies.backend.exception.RecursoNoEncontradoException;
import ar.edu.ies.backend.exception.ValidacionException;
import ar.edu.ies.backend.mapper.CorrelatividadMapper;
import ar.edu.ies.backend.repository.CorrelatividadRepository;
import ar.edu.ies.backend.model.Correlatividad;
import ar.edu.ies.backend.repository.MateriaRepository;
import ar.edu.ies.backend.model.Materia;

@Service
public class CorrelatividadService {

	private final CorrelatividadRepository repo;
	private final MateriaRepository materiaRepo;
	
	public CorrelatividadService(CorrelatividadRepository repo,
								 MateriaRepository materiaRepo) {
		this.repo = repo;
		this.materiaRepo = materiaRepo;
	}
	
	// Listar por materias
	public List<CorrelatividadDto> listarPorMateria(Long idMateria) {
		
		return repo.findByMateriaPrincipal_IdMateria(idMateria)
				.stream()
				.map(CorrelatividadMapper::toDto)
				.collect(Collectors.toList());
	}
	
	// Guardar / Editar
	public CorrelatividadDto guardar(CorrelatividadDto dto) {
		
		Materia principal = materiaRepo.findById(dto.getIdMateriaPrincipal())
				.orElseThrow(() -> new RecursoNoEncontradoException("Materia principal no encontrada"));
		
		Materia requisito = materiaRepo.findById(dto.getIdMateriaRequisito())
				.orElseThrow(() -> new RecursoNoEncontradoException("Materia requisito no encontrada"));
		
		if (principal.getIdMateria().equals(requisito.getIdMateria())) {
			throw new ValidacionException("Una materia no puede ser correlativa de si misma");
		}
		
		Correlatividad correlatividad = CorrelatividadMapper.toEntity(dto, principal, requisito);
		
		correlatividad.setActivo(true);
		
		return CorrelatividadMapper.toDto(repo.save(correlatividad));
	}
	
	public void desactivar(Long id) {
		Correlatividad c = repo.findById(id)
				.orElseThrow(() -> new RecursoNoEncontradoException("Correlativa no encontrada"));
		
		c.setActivo(false);
		repo.save(c);
	}
}
