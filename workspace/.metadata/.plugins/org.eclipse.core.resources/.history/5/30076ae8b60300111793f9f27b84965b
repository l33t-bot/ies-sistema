package ar.edu.ies.backend.service;

import java.util.List;
import java.util.stream.Collectors;

import org.springframework.stereotype.Service;

import ar.edu.ies.backend.dto.MateriaDto;
import ar.edu.ies.backend.dto.PlanDto;
import ar.edu.ies.backend.exception.RecursoNoEncontradoException;
import ar.edu.ies.backend.exception.ValidacionException;
import ar.edu.ies.backend.mapper.MateriaMapper;
import ar.edu.ies.backend.mapper.PlanMapper;
import ar.edu.ies.backend.model.Materia;
import ar.edu.ies.backend.model.Plan;
import ar.edu.ies.backend.repository.MateriaRepository;
import ar.edu.ies.backend.repository.PlanRepository;
import jakarta.transaction.Transactional;

@Service
public class MateriaService {

	private final MateriaRepository materiaRepo;
	private final PlanRepository planRepo;
	
	public MateriaService(MateriaRepository materiaRepo, PlanRepository planRepo) {
		this.materiaRepo = materiaRepo;
		this.planRepo = planRepo;
	}
	
	public List<MateriaDto> listarTodas() {
		return materiaRepo.findAll()
				.stream()
				.map(MateriaMapper::toDto)
				.collect(Collectors.toList());
	}
	
	public List<MateriaDto> listarPorPlan(Long idPlan) {
		return materiaRepo.findByPlan_IdPlan(idPlan)
				.stream()
				.map(MateriaMapper::toDto)
				.collect(Collectors.toList());
	}
	
	public MateriaDto guardar(MateriaDto dto) {
		
		// Validación: Nombre de materia obligatorio
		if (dto.getNombre() == null || dto.getNombre().trim().isEmpty())
			throw new ValidacionException("El nombre de la materia es obligatorio");
		
		if (dto.getAnioCarrera() == null) {
			throw new ValidacionException("El año de la carrera es obligatorio");
		}
		
		// Validar que el plan exista
		Plan plan = planRepo.findById(dto.getIdPlan())
				.orElseThrow(() -> new RecursoNoEncontradoException("Plan no encontrado"));
		
		// Insert
		if (dto.getIdMateria() == null) {
			Materia nueva = MateriaMapper.toEntity(dto, plan);
			return MateriaMapper.toDto(materiaRepo.save(nueva));
		}
		
		// Update
		Materia existente = materiaRepo.findById(dto.getIdMateria())
				.orElseThrow(() -> new RecursoNoEncontradoException("Materia no encontrada"));
		
		existente.setPlan(plan);
		existente.setCodigo(dto.getCodigo());
		existente.setNombre(dto.getNombre());
		existente.setAnioCarrera(dto.getAnioCarrera());
		existente.setEsPromocional(dto.getEsPromocional());
		existente.setActiva(dto.getActiva());
		
		return MateriaMapper.toDto(materiaRepo.save(existente));
	}
	
	public void desactivar(Long id) {
		Materia materia = materiaRepo.findById(id)
				.orElseThrow(() -> new RecursoNoEncontradoException("Materia no encontrada"));
		
		materia.setActiva(false);
		materiaRepo.save(materia);
	}
}
