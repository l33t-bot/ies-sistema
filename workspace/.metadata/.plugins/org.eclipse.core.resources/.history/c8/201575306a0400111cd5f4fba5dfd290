package ar.edu.ies.backend.repository;

import java.util.List;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;

import ar.edu.ies.backend.model.Correlatividad;

public interface CorrelatividadRepository extends JpaRepository<Correlatividad, Long>{

	List<Correlatividad> findByMateriaPrincipal_IdMateria(Long idMateria);
	
	List<Correlatividad> findByMateriaPrincipal_IdMateriaAndActivoTrue(Long idMateria);
	
	// Query personalizada: obtener materias que son requisito de una materia especifica
	@Query("SELECT c FROM Correlatividad c WHERE c.idMateriaPrincipal = :idMateria AND c.activo = true")
	List<Correlatividad> obtenerRequisitos(@Param("idMateria") Long idMateria);
}
